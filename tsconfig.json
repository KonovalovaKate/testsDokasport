{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"],
  "exclude": ["playwright/**", "playwright.config.ts"]
}
