{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node", "@playwright/test"],
    "lib": ["ES2020"]
  },
  "include": ["./**/*.ts", "../playwright.config.ts"]
}
